# Server configuration
PORT=3000
NODE_ENV=production

# JWT Authentication Secret Key (Replace with a strong random string in production)
JWT_SECRET=your_jwt_secret_key_here

# Kakao Local API Rest Key (Optional - for GPS Reverse Geocoding)
KAKAO_REST_API_KEY=your_kakao_rest_api_key_here

# CORS Allowed Origin (e.g. https://your-frontend-domain.vercel.app)
ALLOWED_ORIGIN=*
